# ===================================================================
# FeatureDesk CV Service — environment template
# Copy to `.env` and adjust. `.env` is gitignored and never committed.
# ===================================================================

APP_VERSION=0.1.0
DEBUG=false

# Auth — the frontend sends this as the `X-API-Key` header.
API_KEY=change-me-in-production

# CORS — the live Feature Desk frontend + local Vite dev server.
CORS_ORIGINS=["https://featuredeskx.netlify.app","http://localhost:5173"]

LOG_LEVEL=INFO

# Frame constraints (frames larger than this are downscaled server-side).
MAX_FRAME_WIDTH=1280
MAX_FRAME_HEIGHT=720

# Model paths (downloaded by `python download_models.py`).
YOLO_MODEL_PATH=models/yolo11n.pt
BEST_MODEL_PATH=models/best.pt
FACE_LANDMARKER_PATH=models/face_landmarker.task
POSE_LANDMARKER_PATH=models/pose_landmarker_lite.task

# Load all CV models at startup (true) or lazily on first frame (false).
# Lazy is friendlier for local dev; preload gives lower first-request latency.
PRELOAD_MODELS=false

# Behaviour tuning.
BLINK_EAR_THRESHOLD=0.21
LOOKING_AWAY_YAW_DEG=25
LOOKING_AWAY_PITCH_DEG=20

# Eye-closure escalation (seconds). <= DROWSY stays Focused (normal blink/rest).
DROWSY_SECONDS=7
INATTENTIVE_SECONDS=12
SLEEP_SECONDS=20

# Session lifecycle / limits.
SESSION_TTL_SECONDS=3600
RATE_LIMIT_MAX_CALLS=300
RATE_LIMIT_WINDOW_SECONDS=60
