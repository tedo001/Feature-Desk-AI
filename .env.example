# ==============================================================
# Feature Desk Environment Configuration
# ==============================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit your .env file to version control!

# ==============================================================
# SUPABASE CONFIGURATION (PostgreSQL - Structured Data)
# ==============================================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ==============================================================
# GEMINI AI CONFIGURATION (Multiple keys for auto-rotation)
# ==============================================================
# Get your API keys from: https://makersuite.google.com/app/apikey
# The system automatically rotates to the next key if one hits rate limits.
# VITE_GEMINI_API_KEY is the primary key; _1 through _12 are fallbacks.
# You can configure as many or as few as you need.
VITE_GEMINI_API_KEY=your_primary_gemini_key_here
VITE_GEMINI_API_KEY_1=your_fallback_key_1_here
VITE_GEMINI_API_KEY_2=your_fallback_key_2_here
VITE_GEMINI_API_KEY_3=your_fallback_key_3_here
VITE_GEMINI_API_KEY_4=your_fallback_key_4_here
VITE_GEMINI_API_KEY_5=your_fallback_key_5_here
VITE_GEMINI_API_KEY_6=your_fallback_key_6_here
VITE_GEMINI_API_KEY_7=your_fallback_key_7_here
VITE_GEMINI_API_KEY_8=your_fallback_key_8_here
VITE_GEMINI_API_KEY_9=your_fallback_key_9_here
VITE_GEMINI_API_KEY_10=your_fallback_key_10_here
VITE_GEMINI_API_KEY_11=your_fallback_key_11_here
VITE_GEMINI_API_KEY_12=your_fallback_key_12_here

# ==============================================================
# FIREBASE CONFIGURATION (Firestore - Chat Data Only)
# ==============================================================
# Get these from your Firebase project console:
# https://console.firebase.google.com -> Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ==============================================================
# CLOUDINARY CONFIGURATION (Media File Storage)
# ==============================================================
# Get these from your Cloudinary dashboard:
# https://cloudinary.com/console -> Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# ==============================================================
# OPTIONAL CONFIGURATIONS
# ==============================================================

# Enable debug mode (logs database operations to console)
VITE_DEBUG_MODE=false

# Feature flags (for gradual rollout)
VITE_ENABLE_AI_GRADING=true
VITE_ENABLE_QUESTION_GENERATION=true
VITE_ENABLE_MISTAKE_DETECTION=true
VITE_ENABLE_INTERVENTION_ALERTS=true
